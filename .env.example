# ==========================================
# CONFIGURATION SECRETE — TranspoBot
# Copiez ce fichier en .env et remplissez les valeurs
# NE JAMAIS commiter le fichier .env sur GitHub !
# ==========================================

# 1. Base de données MySQL
DB_HOST=mysql-votre-host.alwaysdata.net
DB_USER=votre_utilisateur
DB_PASSWORD=votre_mot_de_passe_db
DB_NAME=votre_base_de_donnees
DB_PORT=3306

# 2. Clé API Groq (LLM)
GROQ_API_KEY=gsk_...

# 3. Clé secrète JWT (générez une clé aléatoire longue)
JWT_SECRET=votre_cle_secrete_jwt_tres_longue_ici

# 4. Credentials Super Admin
SUPERADMIN_USERNAME=votre_username_superadmin
SUPERADMIN_PASSWORD=votre_mot_de_passe_superadmin_fort

# 5. SMTP — Envoi d'emails (activation de compte)
SMTP_HOST=smtp-votre-host.alwaysdata.net
SMTP_PORT=587
SMTP_USER=votre-adresse@alwaysdata.net
SMTP_PASSWORD=votre_mot_de_passe_smtp

# 6. URL publique de l'application
APP_URL=https://transpobot-api.onrender.com
